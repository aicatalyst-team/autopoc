# AutoPoC Credentials Secret
#
# Contains all credentials needed by the autopoc Job.
# Copy this file to secret.yaml, fill in the values, and apply:
#
#   cp deploy/secret.yaml.example deploy/secret.yaml
#   # Edit deploy/secret.yaml with real values
#   kubectl apply -f deploy/secret.yaml
#
# WARNING: deploy/secret.yaml is gitignored — never commit real credentials.
#
# Not all fields are required. Which ones you need depends on your
# configuration (LLM provider, fork target, build strategy).
#
# Required fields are marked with (REQUIRED).
# Optional fields are marked with (optional) and their defaults.
---
apiVersion: v1
kind: Secret
metadata:
  name: autopoc-credentials
  namespace: autopoc
  labels:
    app: autopoc
type: Opaque
stringData:
  # ═══════════════════════════════════════════════════════════
  # LLM Provider — choose ONE of Anthropic, Vertex AI, or OpenAI-compatible
  # ═══════════════════════════════════════════════════════════

  # Option A: Anthropic (REQUIRED if not using Vertex or OpenAI-compatible)
  ANTHROPIC_API_KEY: "sk-ant-..."

  # Option B: Google Vertex AI (REQUIRED if not using Anthropic or OpenAI-compatible)
  # VERTEX_PROJECT: "my-gcp-project"
  # VERTEX_LOCATION: "us-east5"    # (optional, defaults to us-east5)

  # Option C: OpenAI-compatible endpoint (vLLM, Ollama, etc.)
  # LLM_BASE_URL: "http://my-vllm-svc.namespace:8000/v1"
  # LLM_API_KEY: "none"           # use "none" if no auth required
  # LLM_MODEL: "qwen2.5-coder-32b"  # (REQUIRED when using LLM_BASE_URL)

  # LLM model override (optional for Anthropic/Vertex, REQUIRED for OpenAI-compatible)
  # LLM_MODEL: "claude-sonnet-4-20250514"

  # ═══════════════════════════════════════════════════════════
  # Fork Target — where to fork source repos
  # ═══════════════════════════════════════════════════════════

  # "gitlab" or "github" (optional, defaults to "gitlab")
  FORK_TARGET: "github"

  # GitHub credentials (REQUIRED if FORK_TARGET=github)
  GITHUB_TOKEN: "ghp_..."
  GITHUB_ORG: "my-org"             # (optional, forks to authenticated user if unset)

  # GitLab credentials (REQUIRED if FORK_TARGET=gitlab)
  # GITLAB_URL: "https://gitlab.example.com"
  # GITLAB_TOKEN: "glpat-..."
  # GITLAB_GROUP: "poc"

  # ═══════════════════════════════════════════════════════════
  # Quay Container Registry
  # ═══════════════════════════════════════════════════════════

  # (optional, defaults to "quay.io")
  # QUAY_REGISTRY: "quay.io"

  # (REQUIRED) Organization or username for pushed images
  QUAY_ORG: "my-org"

  # (REQUIRED) Robot account token or OAuth token
  QUAY_TOKEN: "..."

  # (optional) Robot account username (e.g. "myuser+robotname").
  # Set this when using a robot account. Leave unset for OAuth tokens.
  # QUAY_USERNAME: "myuser+robotname"

  # ═══════════════════════════════════════════════════════════
  # OpenShift Cluster
  # ═══════════════════════════════════════════════════════════

  # (REQUIRED) OpenShift API URL
  OPENSHIFT_API_URL: "https://api.cluster.example.com:6443"

  # (REQUIRED) OpenShift bearer token (get with: oc whoami -t)
  OPENSHIFT_TOKEN: "sha256~..."

  # (optional, defaults to "poc")
  # OPENSHIFT_NAMESPACE_PREFIX: "poc"
