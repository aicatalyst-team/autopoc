*.md
!README.md
docs/
.opencode/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db
nohup.out

# CI/CD (not needed in image)
.github/

# Misc scratch files
*.log
quay_login.py
quay_setup.py
