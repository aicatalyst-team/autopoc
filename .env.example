# AutoPoC Configuration
#
# Usage: source this file before running autopoc, or export the variables:
#   source .env && autopoc --name my-project --repo https://github.com/...
#
# Note: this file is sourced by bash, so shell commands like $(cat ...) work.
# Python's dotenv does NOT execute shell commands, but environment variables
# set via `source` take priority over .env file values.

# --- LLM ---
# You must provide either ANTHROPIC_API_KEY OR VERTEX_PROJECT
ANTHROPIC_API_KEY=sk-ant-...

# Vertex AI Configuration (Alternative to Anthropic API Key)
# VERTEX_PROJECT=my-google-cloud-project
# VERTEX_LOCATION=us-east5

# Optional: Override the default model
# LLM_MODEL=claude-3-5-haiku@20241022

# Max retries for LLM API calls (default 0 to fail fast on rate limits instead of hanging)
LLM_MAX_RETRIES=0

# --- Fork target ---
# Where to fork the source repo: "gitlab" (default) or "github"
# Can be overridden with --target flag on the CLI
FORK_TARGET=gitlab

# --- GitLab (required when FORK_TARGET=gitlab) ---
GITLAB_URL=https://gitlab.internal.example.com
GITLAB_TOKEN=glpat-...
GITLAB_GROUP=poc-demos

# --- GitHub (required when FORK_TARGET=github) ---
# Creates a true GitHub fork (parent-child relationship) via the GitHub API.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_ORG=my-org    # Optional — if unset, forks to the authenticated user's account

# --- Quay Container Registry ---
QUAY_REGISTRY=quay.io
QUAY_ORG=my-org
QUAY_TOKEN=...

# --- OpenShift ---
OPENSHIFT_API_URL=https://api.cluster.example.com:6443
OPENSHIFT_TOKEN=sha256~...
OPENSHIFT_NAMESPACE_PREFIX=poc

# --- Retry limits ---
MAX_BUILD_RETRIES=3
MAX_DEPLOY_RETRIES=2
MAX_CONTAINER_FIX_RETRIES=2

# --- Working directory ---
WORK_DIR=/tmp/autopoc

# --- LangSmith tracing (optional) ---
# Enable tracing to LangSmith for debugging LLM calls and agent behavior.
# Sign up at https://smith.langchain.com/ to get an API key.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=autopoc
#
# For LangGraph Studio: a langgraph.json config file is included in the repo root.
# Open the project directory in LangGraph Studio to visualize and debug runs.
