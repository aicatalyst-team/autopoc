# AutoPoC Configuration
#
# Usage: source this file before running autopoc, or export the variables:
#   source .env && autopoc --name my-project --repo https://github.com/...
#
# Note: this file is sourced by bash, so shell commands like $(cat ...) work.
# Python's dotenv does NOT execute shell commands, but environment variables
# set via `source` take priority over .env file values.

# --- LLM ---
# You must provide either ANTHROPIC_API_KEY OR VERTEX_PROJECT
ANTHROPIC_API_KEY=sk-ant-...

# Vertex AI Configuration (Alternative to Anthropic API Key)
# VERTEX_PROJECT=my-google-cloud-project
# VERTEX_LOCATION=us-east5

# Max retries for LLM API calls (default 0 to fail fast on rate limits instead of hanging)
LLM_MAX_RETRIES=0

# --- GitLab (self-hosted) ---
GITLAB_URL=https://gitlab.internal.example.com
GITLAB_TOKEN=glpat-...
GITLAB_GROUP=poc-demos

# --- Quay Container Registry ---
QUAY_REGISTRY=quay.io
QUAY_ORG=my-org
QUAY_TOKEN=...

# --- OpenShift ---
OPENSHIFT_API_URL=https://api.cluster.example.com:6443
OPENSHIFT_TOKEN=sha256~...
OPENSHIFT_NAMESPACE_PREFIX=poc

# --- Build ---
MAX_BUILD_RETRIES=3

# --- Working directory ---
WORK_DIR=/tmp/autopoc

# --- LangSmith tracing (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=autopoc
